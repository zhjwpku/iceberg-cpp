#
# This config sets the following variables in your project::
#
#   iceberg_rest_FOUND - true if iceberg_rest is found on the system
#   iceberg_rest_VERSION - version of the found iceberg_rest
#
# This config sets the following targets (if built) in your project::
#
#   iceberg::iceberg_rest_shared
#   iceberg::iceberg_rest_static

@PACKAGE_INIT@

set(ICEBERG_REST_SYSTEM_DEPENDENCIES "@ICEBERG_REST_SYSTEM_DEPENDENCIES@")

include(CMakeFindDependencyMacro)

find_dependency(iceberg)

macro(iceberg_rest_find_dependencies dependencies)
  if(DEFINED CMAKE_MODULE_PATH)
    set(ICEBERG_REST_CMAKE_MODULE_PATH_OLD ${CMAKE_MODULE_PATH})
  else()
    unset(ICEBERG_REST_CMAKE_MODULE_PATH_OLD)
  endif()
  set(CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")

  foreach(dependency ${dependencies})
    find_dependency(${dependency})
  endforeach()

  if(DEFINED ICEBERG_REST_CMAKE_MODULE_PATH_OLD)
    set(CMAKE_MODULE_PATH ${ICEBERG_REST_CMAKE_MODULE_PATH_OLD})
    unset(ICEBERG_REST_CMAKE_MODULE_PATH_OLD)
  else()
    unset(CMAKE_MODULE_PATH)
  endif()
endmacro()

# cpr (+ OpenSSL/CURL when bundled).
iceberg_rest_find_dependencies("${ICEBERG_REST_SYSTEM_DEPENDENCIES}")

include("${CMAKE_CURRENT_LIST_DIR}/iceberg_rest-targets.cmake")

check_required_components(iceberg_rest)
