          <declname>client_id</declname>
        </param>
        <param>
          <type>const std::string &amp;</type>
          <declname>client_secret</declname>
        </param>
        <param>
          <type>const std::string &amp;</type>
          <declname>scope</declname>
        </param>
        <param>
          <type>bool</type>
          <declname>keep_refreshed</declname>
        </param>
        <param>
          <type>const std::unordered_map&lt; std::string, std::string &gt; &amp;</type>
          <declname>optional_oauth_params</declname>
