      <memberdef kind="function" id="classiceberg_1_1TransformUtil_1a2931804944c77470187b77602489d8ee" prot="public" static="yes" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>Result&lt; int64_t &gt;</type>
        <definition>Result&lt; int64_t &gt; iceberg::TransformUtil::ParseTimestampWithZone</definition>
        <argsstring>(std::string_view str)</argsstring>
        <name>ParseTimestampWithZone</name>
        <qualifiedname>iceberg::TransformUtil::ParseTimestampWithZone</qualifiedname>
        <param>
          <type>std::string_view</type>
          <declname>str</declname>
        </param>
        <briefdescription>
<para>Parses a timestamp-with-zone string into microseconds since epoch (UTC). </para>
        </briefdescription>
        <detaileddescription>
<para>Accepts the same formats as ParseTimestamp, with a timezone suffix: &quot;Z&quot;, &quot;+HH:mm&quot;, or &quot;-HH:mm&quot;. Non-UTC offsets are converted to UTC. The seconds and fractional parts are optional (e.g. &quot;yyyy-MM-ddTHH:mm+00:00&quot;).</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>str</parametername>
</parameternamelist>
<parameterdescription>
<para>The timestamp string to parse. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>The number of microseconds since epoch (UTC), or an error. </para>
</simplesect>
</para>
        </detaileddescription>
