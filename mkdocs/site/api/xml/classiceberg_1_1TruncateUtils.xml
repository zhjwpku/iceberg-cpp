        <argsstring>(T v, int32_t W)</argsstring>
        <name>TruncateInteger</name>
        <qualifiedname>iceberg::TruncateUtils::TruncateInteger</qualifiedname>
        <param>
          <type>T</type>
          <declname>v</declname>
        </param>
        <param>
