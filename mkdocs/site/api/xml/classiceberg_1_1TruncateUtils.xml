        <argsstring>(std::string source, size_t L)</argsstring>
        <name>TruncateUTF8</name>
        <qualifiedname>iceberg::TruncateUtils::TruncateUTF8</qualifiedname>
        <param>
          <type>std::string</type>
          <declname>source</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>L</declname>
